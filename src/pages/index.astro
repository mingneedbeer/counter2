---
import Layout from '../layouts/Layout.astro';
---

<Layout>
<div class="hero min-h-[calc(100vh-4rem)] bg-gradient-to-br from-primary/10 via-base-200 to-secondary/10">
  <div class="hero-content text-center">
    <div class="max-w-2xl">
      <div class="badge badge-primary badge-outline mb-4">Secure & Simple</div>
      <h1 class="text-5xl md:text-6xl font-bold">
        Authentication
        <span class="text-primary">Made Simple</span>
      </h1>
      <p class="text-xl text-base-content/70 mt-6 mb-8 leading-relaxed">
        A modern auth solution supporting email/password and passkeys.
      </p>
      <div class="flex justify-center gap-4">
        <a href="/login" class="btn btn-primary btn-lg px-8">
          Login
          <svg xmlns="http://www.w3.org/2000/svg" class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" /></svg>
        </a>
        <a href="/register" class="btn btn-outline btn-lg px-8">
          Get Started
          <svg xmlns="http://www.w3.org/2000/svg" class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-16">
        <div class="card bg-base-100/50 backdrop-blur shadow-sm">
          <div class="card-body items-center text-center">
            <div class="size-12 rounded-full bg-primary/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
            </div>
            <h3 class="font-semibold">Password Auth</h3>
            <p class="text-sm text-base-content/60">Secure bcrypt-hashed passwords</p>
          </div>
        </div>
        <div class="card bg-base-100/50 backdrop-blur shadow-sm">
          <div class="card-body items-center text-center">
            <div class="size-12 rounded-full bg-secondary/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-6 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" /></svg>
            </div>
            <h3 class="font-semibold">Passkeys</h3>
            <p class="text-sm text-base-content/60">Passwordless WebAuthn login</p>
          </div>
        </div>
        <div class="card bg-base-100/50 backdrop-blur shadow-sm">
          <div class="card-body items-center text-center">
            <div class="size-12 rounded-full bg-accent/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <h3 class="font-semibold">JWT Sessions</h3>
            <p class="text-sm text-base-content/60">Secure cookie-based sessions</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
</Layout>