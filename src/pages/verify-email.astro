---
import Layout from '../layouts/Layout.astro';
---

<Layout>
<div class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-4">
  <div class="card w-full max-w-md bg-base-100 shadow-xl">
    <div class="card-body items-center text-center">
      <div class="size-16 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
      </div>
      <h2 class="card-title text-2xl">Check Your Email</h2>
      <p class="text-base-content/60 mt-2">
        We've sent a verification link to your email address. Click the link to activate your account.
      </p>
      <div class="alert bg-base-200 mt-4 text-sm text-left">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <span>In development mode, the verification link is printed in the server console.</span>
      </div>
      <a href="/login" class="btn btn-primary mt-6 w-full">Go to Login</a>
    </div>
  </div>
</div>
</Layout>