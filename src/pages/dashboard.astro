---
import Layout from '../layouts/Layout.astro';
import { verifyToken } from '../lib/auth';
import PasskeyRegister from '../components/PasskeyRegister';

export const prerender = false;

const token = Astro.cookies.get("token")?.value;
const payload = token ? verifyToken(token) : null;

if (!payload) {
  return Astro.redirect("/login");
}
---

<Layout>
<div class="min-h-[calc(100vh-4rem)] flex items-start justify-center px-4 py-8">
  <div class="w-full max-w-md space-y-6">
    <div class="card bg-base-100 shadow-xl">
      <div class="card-body items-center text-center">
        <div class="avatar placeholder mb-2">
          <div class="bg-primary text-primary-content rounded-full w-20 h-20 ring ring-primary/20 ring-offset-2 ring-offset-base-100">
            <span class="text-3xl font-bold">{payload.email.charAt(0).toUpperCase()}</span>
          </div>
        </div>
        <p class="text-sm text-base-content/60">Signed in as</p>
        <h2 class="card-title text-2xl mt-0">{payload.email}</h2>
      </div>
    </div>

    <div class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <h3 class="font-semibold flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
          Profile Details
        </h3>
        <div class="space-y-3 mt-3">
          <div class="flex justify-between items-center py-2 px-3 bg-base-200 rounded-box">
            <span class="text-sm text-base-content/60">User ID</span>
            <span class="text-sm font-mono font-semibold">{payload.userId}</span>
          </div>
          <div class="flex justify-between items-center py-2 px-3 bg-base-200 rounded-box">
            <span class="text-sm text-base-content/60">Email</span>
            <span class="text-sm font-semibold">{payload.email}</span>
          </div>
        </div>
      </div>
    </div>

    <div class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <h3 class="font-semibold flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-5 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" /></svg>
          Passkey Security
        </h3>
        <p class="text-sm text-base-content/60 mt-1 mb-3">
          Register a passkey for passwordless login using your device's biometrics or PIN.
        </p>
        <PasskeyRegister client:load />
      </div>
    </div>

    <div class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <h3 class="font-semibold flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
          API Documentation
        </h3>
        <p class="text-sm text-base-content/60 mt-1 mb-3">
          Browse the full API specification with Swagger UI.
        </p>
        <a href="/docs" class="btn btn-accent btn-sm w-full">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          Open API Docs
        </a>
      </div>
    </div>

    <div class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <h3 class="font-semibold flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-5 text-error" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
          Sessions
        </h3>
        <p class="text-sm text-base-content/60 mt-1 mb-3">
          Sign out of your account. You can log back in anytime.
        </p>
        <a href="/api/auth/logout" class="btn btn-outline btn-error btn-sm w-full">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
          Logout
        </a>
      </div>
    </div>
  </div>
</div>
</Layout>